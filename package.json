{
  "name": "daily-context",
  "version": "0.1.0",
  "description": "Obsidian plugin that exposes structured daily context for composable vault automations.",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "typecheck": "tsc -noEmit -skipLibCheck",
    "test:feature": "node test/run-feature-tests.mjs",
    "lint": "tsc -noEmit -skipLibCheck"
  },
  "keywords": ["obsidian", "plugin", "daily-notes", "context", "dataview"],
  "author": "bobthearsonist",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bobthearsonist/daily-context.git"
  },
  "homepage": "https://github.com/bobthearsonist/daily-context#readme",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.20.0",
    "obsidian": "latest",
    "tslib": "^2.6.0",
    "typescript": "^5.4.0"
  }
}
